# ==============================
# 🔴 CRITICAL: Migration Files - ABSOLUTELY FORBIDDEN 🔴
# ==============================

# ALL migration files in ANY app - NEVER EVER commit them!
# This blocks migrations from ALL apps including those in 'apps' folder
**/migrations/*.py
!**/migrations/__init__.py
**/migrations/*.pyc
**/migrations/*.pyo
**/migrations/*.orig
**/migrations/*.rej

# Also block migrations in apps directory specifically
apps/*/migrations/*.py
!apps/*/migrations/__init__.py
apps/*/migrations/*.pyc

# Any other migration-related files
**/migrations/__pycache__/
**/migrations/.DS_Store

# ==============================
# ⚠️ CRITICAL: Django Settings - ABSOLUTELY FORBIDDEN ⚠️
# ==============================

# Block ALL settings files with sensitive data
**/settings.py
**/settings/*.py
!**/settings/__init__.py
**/local_settings.py
**/production_settings.py
**/dev_settings.py
**/secret_settings.py
**/settings_local.py

# Specifically block web/settings.py
web/settings.py
web/settings/*.py
!web/settings/__init__.py

# Any files containing SECRET_KEY, passwords, etc.
*secret*.py
*key*.py
*credential*.py
*.pem
*.key
*.crt
*.p12

