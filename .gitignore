# ==============================
# 🔥 EXTRA SAFETY: Block ALL media and uploads in every possible location
# ==============================

# Any directory named media, upload, uploads, files
**/media/
**/uploads/
**/upload/
**/files/


# Block specific media paths
media/
media/*
media/**/*
uploads/
uploads/**/*
files/
files/**/*

# ==============================
# Custom for your project structure
# ==============================

# Apps directory - but keep only __init__.py



apps/*/__pycache__/


# Web directory - block everything except __init__.py and maybe urls.py



web/settings.py
web/settings/
web/__pycache__/

# ==============================
# 📌 IMPORTANT: ALWAYS keep these files
# ==============================

# Ensure these essential files are tracked
!**/__init__.py
!**/migrations/__init__.py
!manage.py
!requirements.txt
!requirements/*.txt
!README.md
!README.rst
!.gitignore
!Dockerfile
!docker-compose.yml
!Makefile
!.env.example
!.pre-commit-config.yaml

# ==============================
# Final safety - block ANY file that might contain sensitive data
# ==============================

# Files containing patterns that might indicate sensitive data
*secret*
*password*
*credential*
*token*
*key*
*.pem
*.crt
*.key
*.p12
*.pfx
*.cer
*.csr

# Block all compressed files in media directories
/media/**/*.zip
/media/**/*.rar
/media/**/*.7z
/media/**/*.tar
/media/**/*.gz
/uploads/**/*.zip
/uploads/**/*.rar